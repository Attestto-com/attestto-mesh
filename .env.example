# Attestto Mesh node — environment template
# Copy to .env and edit as needed: cp .env.example .env

# TCP listen port (host + container)
MESH_LISTEN_PORT=4001

# Comma-separated multiaddrs of bootstrap peers to dial on start.
# Get these from another node's startup logs ("Listening on: /ip4/.../tcp/4001/p2p/12D3Koo...").
# Leave empty to start a fresh isolated node.
MESH_BOOTSTRAP_PEERS=

# Mesh isolation id — peers only gossip with same MESH_ID.
MESH_ID=attestto-cr

# Storage cap in MB
MESH_MAX_STORAGE_MB=250

# Set to 1 only on anchor nodes with a public IP — enables circuit-relay server
# so NAT'd peers can use this node to traverse.
MESH_RELAY_SERVER=0

# Status log interval (ms)
MESH_STATUS_INTERVAL=30000

# Local HTTP RPC for driving PUT/GET and exposing /metrics.
# 0 = disabled.
# In docker-compose this port is published to host 127.0.0.1 only, but the
# daemon inside the container must bind 0.0.0.0 to be reachable across the
# docker bridge — so MESH_RPC_TOKEN is REQUIRED for docker. Generate one:
#   openssl rand -hex 32
MESH_RPC_PORT=4101
MESH_RPC_TOKEN=
